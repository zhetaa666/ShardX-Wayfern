# Public API listen port.
PORT=8080
HOST=0.0.0.0

# Generate strong token: openssl rand -hex 32
SYNC_TOKEN=replace-with-long-random-token
WORKSPACE_ID=default
DATA_DIR=/app/data
DB_PATH=/app/data/sync.sqlite
MAX_BODY_BYTES=52428800

# MinIO object storage for storage bundles.
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=shardxsync
MINIO_SECRET_KEY=replace-with-long-minio-password
MINIO_BUCKET=shardx-sync
MINIO_CONSOLE_PORT=9001
